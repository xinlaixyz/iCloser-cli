{
  "name": "icloser-vscode",
  "displayName": "icloser Agent Shell",
  "description": "Terminal AI Engineering Assistant — understand, edit, verify, report",
  "version": "0.1.0",
  "publisher": "icloser",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other", "Programming Languages"],
  "activationEvents": ["onCommand:icloser.openTerminal", "onCommand:icloser.runTask"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      { "command": "icloser.openTerminal", "title": "icloser: Open Terminal" },
      { "command": "icloser.runTask", "title": "icloser: Run Task" },
      { "command": "icloser.analyzeProject", "title": "icloser: Analyze Project" },
      { "command": "icloser.generateDocs", "title": "icloser: Generate Documentation" },
      { "command": "icloser.fixError", "title": "icloser: Fix Error" }
    ],
    "keybindings": [
      { "command": "icloser.openTerminal", "key": "ctrl+shift+i", "mac": "cmd+shift+i" },
      { "command": "icloser.runTask", "key": "ctrl+shift+t", "mac": "cmd+shift+t" }
    ],
    "configuration": {
      "title": "icloser",
      "properties": {
        "icloser.provider": { "type": "string", "default": "deepseek", "description": "AI Provider" },
        "icloser.model": { "type": "string", "default": "", "description": "Model name" }
      }
    }
  }
}
