{
  "name": "icloser-agent-shell",
  "version": "0.1.0",
  "description": "iCloser Agent Shell - AI 工程执行 CLI 系统。理解项目、修改代码、自动验证、生成报告。",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ic": "./dist/index.js",
    "iCloser": "./dist/index.js"
  },
  "files": [
    "dist/",
    "skills/",
    "templates/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run release:trust:full",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "node scripts/check-lint.mjs",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.mjs\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.mjs\"",
    "test": "node --no-warnings ./node_modules/vitest/vitest.mjs run",
    "test:watch": "node --no-warnings ./node_modules/vitest/vitest.mjs",
    "test:coverage": "node --no-warnings ./node_modules/vitest/vitest.mjs run --coverage",
    "test:acceptance": "node --no-warnings ./node_modules/vitest/vitest.mjs run tests/acceptance",
    "smoke": "node scripts/release-smoke.mjs",
    "package": "node scripts/build-package.mjs",
    "smoke:project": "node scripts/real-project-smoke.mjs",
    "smoke:first-run": "node scripts/first-run-smoke.mjs",
    "smoke:repl": "node scripts/repl-first-run-smoke.mjs",
    "smoke:repl:apikey": "node scripts/repl-apikey-paste-smoke.mjs",
    "smoke:repl:init": "node scripts/repl-init-refresh-smoke.mjs",
    "smoke:repl:e2e": "node scripts/repl-beginner-e2e-smoke.mjs",
    "smoke:memory": "node scripts/memory-event-smoke.mjs",
    "smoke:all": "node scripts/full-smoke.mjs",
    "smoke:keep": "node -e \"process.env.ICLOSER_KEEP_SMOKE='1'; import('./scripts/release-smoke.mjs')\"",
    "setup": "node dist/index.js setup",
    "postinstall": "node -e \"const m='\\niCloser Agent Shell 已安装。\\n\\n快速开始：\\n  ic setup    首次配置向导\\n  ic --help   查看所有命令\\n  iCloser     也可用此命令（兼容旧习惯）\\n\\n如果 ic 命令不可用：\\n  全局安装：npm install -g icloser-agent-shell\\n  本地开发：npm link\\n  不用全局命令：npm run setup\\n'; console.log(m)\"",
    "smoke:autopilot": "node scripts/autopilot-smoke.mjs",
    "smoke:repair": "node scripts/autopilot-repair-smoke.mjs",
    "smoke:loop": "node scripts/loop-tool-smoke.mjs",
    "smoke:multilang": "node scripts/multilang-smoke.mjs",
    "smoke:web-search": "node scripts/web-search-smoke.mjs",
    "smoke:agent": "node scripts/agent-smoke.mjs",
    "smoke:ai": "node scripts/ai-capability-smoke.mjs",
    "smoke:tools": "node scripts/tool-capability-smoke.mjs",
    "smoke:golden": "node scripts/golden-path-smoke.mjs",
    "smoke:golden:real": "node scripts/golden-path-real.mjs",
    "smoke:golden:scenarios": "node scripts/golden-path-scenarios.mjs",
    "smoke:real-projects": "node scripts/real-project-suite.mjs",
    "macos:acceptance": "node scripts/macos-acceptance.mjs",
    "release:trust": "node scripts/release-trust-check.mjs",
    "release:trust:full": "node scripts/release-trust-check.mjs --full",
    "release:checksum": "node scripts/release-checksum.mjs",
    "perf": "node scripts/perf-bench.mjs",
    "acceptance": "node scripts/live-acceptance.mjs",
    "release": "node scripts/release.mjs"
  },
  "keywords": [
    "cli",
    "ai",
    "agent",
    "code-generator",
    "dev-tools",
    "ai-coding-assistant",
    "chinese",
    "deepseek",
    "claude"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iCloser/icloser-agent-shell.git"
  },
  "homepage": "https://github.com/iCloser/icloser-agent-shell",
  "author": "iCloser",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "preferGlobal": true,
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "fs-extra": "^11.2.0",
    "ignore": "^6.0.2",
    "openai": "^4.77.0",
    "ora": "^8.1.1",
    "pdf-parse": "^2.4.5",
    "semver": "^7.6.3",
    "tree-sitter": "^0.22.4",
    "tree-sitter-c": "^0.24.1",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-kotlin": "^0.3.8",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-sql": "^0.1.0",
    "tree-sitter-typescript": "^0.23.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.0",
    "@types/semver": "^7.5.8",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "tree-sitter-cli": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
