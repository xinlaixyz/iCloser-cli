# tree-sitter-cpp@0.23.x declares peerOptional tree-sitter@^0.21, while the
# other grammars (and the root) use tree-sitter@^0.22. The mismatch is a benign
# optional-peer conflict — every grammar loads and the suite passes — but npm v7+
# strict resolution makes `npm ci` fail on a clean install (e.g. in CI/Docker).
# Use legacy (npm v6) peer resolution so installs are reproducible everywhere.
legacy-peer-deps=true
